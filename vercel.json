{
  "functions": {
    "api/python.py": {
      "maxDuration": 10
    },
    "api/go.go": {
      "maxDuration": 10
    },
    "api/php.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/rust.rs": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/python",
      "destination": "/api/python.py"
    },
    {
      "source": "/api/php",
      "destination": "/api/php.php"
    },
    {
      "source": "/api/go",
      "destination": "/api/go.go"
    },
    {
      "source": "/api/rust",
      "destination": "/api/rust.rs"
    }
  ]
}