{
  "functions": {
    "api/python/index.py": {
      "maxDuration": 10,
      "includeFiles": "api/python/index.py"
    },
    "api/go/index.go": {
      "maxDuration": 10,
      "includeFiles": "api/go/index.go"
    },
    "api/php/index.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": "api/php/index.php"
    },
    "api/rust/index.rs": {
      "maxDuration": 10,
      "includeFiles": "api/rust/index.rs"
    }
  },
  "rewrites": [
    {
      "source": "/api/python",
      "destination": "/api/python/index.py"
    },
    {
      "source": "/api/php",
      "destination": "/api/php/index.php"
    },
    {
      "source": "/api/go",
      "destination": "/api/go/index.go"
    },
    {
      "source": "/api/rust",
      "destination": "/api/rust/index.rs"
    }
  ]
}