{
  "functions": {
    "api/python.py": { "maxDuration": 10 },
    "api/go.go": { "maxDuration": 10 },
    "api/php.php": { "runtime": "vercel-php@0.9.0" },
    "api/rust.rs": { "runtime": "vercel-rust@4.0.11" }
  },
  "routes": [
    { "src": "/api/python", "dest": "/api/python.py" },
    { "src": "/api/php", "dest": "/api/php.php" },
    { "src": "/api/go", "dest": "/api/go.go" },
    { "src": "/api/rust", "dest": "/api/rust.rs" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
